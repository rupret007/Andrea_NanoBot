# Runtime / Gateway
ONECLI_URL=http://127.0.0.1:10254
# Optional assistant display name and trigger prefix
# ASSISTANT_NAME=Andrea

# Core agent credentials (choose one approach)
# 1) Anthropic native:
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=...
# ANTHROPIC_AUTH_TOKEN=...
#
# 2) OpenAI key with an Anthropic-compatible gateway:
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint
# OPENAI_BASE_URL=https://your-anthropic-compatible-endpoint
# OPENAI_API_KEY=sk-openai-...
#
# 3) 9Router (including Cursor-backed routing):
# ANTHROPIC_BASE_URL=http://127.0.0.1:20128/v1
# ANTHROPIC_AUTH_TOKEN=your-9router-api-key
# NANOCLAW_AGENT_MODEL=cu/default
# Note: localhost/127.0.0.1 endpoints are rewritten to the runtime host alias
# inside containers (host.docker.internal or host.containers.internal).
#
# IMPORTANT: Do not point OPENAI_BASE_URL/ANTHROPIC_BASE_URL to
# https://api.openai.com/v1 for the core agent runtime.
# NanoClaw core expects Anthropic-compatible API semantics.
#
# Windows + Podman local gateway defaults:
# ANTHROPIC_BASE_URL=http://host.containers.internal:4000
# OPENAI_API_KEY=sk-openai-...

# 4) Cursor Cloud Agents API (optional but required for direct Cursor job control):
# CURSOR_API_KEY=cursor_api_...
# CURSOR_API_BASE_URL=https://api.cursor.com
# CURSOR_API_TIMEOUT_MS=20000
# CURSOR_WEBHOOK_SECRET=replace-with-random-secret
# CURSOR_MAX_ACTIVE_JOBS_PER_CHAT=4

# Optional OpenAI integrations (e.g., transcription skills)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional model override for Claude Agent SDK inside containers.
# Useful for OpenAI-compatible gateways that do not support the latest
# Claude default aliases yet.
# NANOCLAW_AGENT_MODEL=claude-3-5-sonnet-latest

# Channel credentials (enable one or more)
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# DISCORD_BOT_TOKEN=
