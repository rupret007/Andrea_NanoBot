# Runtime / Gateway
ONECLI_URL=http://127.0.0.1:10254
# Optional assistant display name and trigger prefix
# ASSISTANT_NAME=Andrea

# Core agent credentials (choose one approach)
# 1) Anthropic native:
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=...
# ANTHROPIC_AUTH_TOKEN=...
#
# 2) OpenAI key with an Anthropic-compatible gateway:
# ANTHROPIC_BASE_URL=https://your-anthropic-compatible-endpoint
# OPENAI_BASE_URL=https://your-anthropic-compatible-endpoint
# OPENAI_API_KEY=sk-openai-...
#
# 3) 9Router (including Cursor-backed routing):
# ANTHROPIC_BASE_URL=http://127.0.0.1:20128/v1
# ANTHROPIC_AUTH_TOKEN=your-9router-api-key
# NANOCLAW_AGENT_MODEL=cu/default
# CURSOR_GATEWAY_HINT=9router
# Note: localhost/127.0.0.1 endpoints are rewritten to the runtime host alias
# inside containers (host.docker.internal or host.containers.internal).
#
# IMPORTANT: Do not point OPENAI_BASE_URL/ANTHROPIC_BASE_URL to
# https://api.openai.com/v1 for the core agent runtime.
# NanoClaw core expects Anthropic-compatible API semantics.
#
# Windows + Podman local gateway defaults:
# ANTHROPIC_BASE_URL=http://host.containers.internal:4000
# OPENAI_API_KEY=sk-openai-...

# 4) Cursor Cloud Agents API (optional but required for direct Cursor job control):
# CURSOR_API_KEY=cursor_api_...
# CURSOR_API_BASE_URL=https://api.cursor.com
# CURSOR_API_TIMEOUT_MS=20000
# CURSOR_API_MAX_RETRIES=2
# CURSOR_API_RETRY_BASE_MS=800
# CURSOR_WEBHOOK_SECRET=replace-with-random-secret
# CURSOR_MAX_ACTIVE_JOBS_PER_CHAT=4
#
# 4b) Cursor Desktop Bridge (recommended when you want Andrea to use the
# Cursor machine you normally work on, e.g. your Mac while you're away):
# Run `npm run cursor:bridge` on that machine, then point NanoClaw here.
# CURSOR_DESKTOP_BRIDGE_URL=https://your-mac-bridge.example.com
# CURSOR_DESKTOP_BRIDGE_TOKEN=replace-with-random-secret
# CURSOR_DESKTOP_BRIDGE_TIMEOUT_MS=30000
# CURSOR_DESKTOP_BRIDGE_LABEL=Jeff MacBook Pro
#
# Optional on the machine running the bridge:
# CURSOR_DESKTOP_BRIDGE_HOST=127.0.0.1
# CURSOR_DESKTOP_BRIDGE_PORT=4124
# CURSOR_DESKTOP_CLI_PATH=cursor-agent
# CURSOR_DESKTOP_DEFAULT_CWD=/Users/you/src/your-main-workspace
# CURSOR_DESKTOP_FORCE=true

# 5) Amazon Business shopping + approval flow (optional)
# Andrea uses Amazon Business APIs for product search and guarded ordering.
# Consumer Amazon checkout automation is NOT the default path in this repo.
# Recommended for first setup:
# AMAZON_BUSINESS_ORDER_MODE=trial
# AMAZON_PURCHASE_APPROVAL_TTL_MINUTES=30
#
# Required for Amazon Business search:
# AMAZON_BUSINESS_API_BASE_URL=https://na.business-api.amazon.com
# AMAZON_BUSINESS_AWS_REGION=us-east-1
# AMAZON_BUSINESS_LWA_CLIENT_ID=
# AMAZON_BUSINESS_LWA_CLIENT_SECRET=
# AMAZON_BUSINESS_LWA_REFRESH_TOKEN=
# AMAZON_BUSINESS_AWS_ACCESS_KEY_ID=
# AMAZON_BUSINESS_AWS_SECRET_ACCESS_KEY=
# AMAZON_BUSINESS_USER_EMAIL=buyer@example.com
#
# Optional search refinements:
# AMAZON_BUSINESS_AWS_SESSION_TOKEN=
# AMAZON_BUSINESS_GROUP_TAG=
# AMAZON_BUSINESS_PRODUCT_REGION=US
# AMAZON_BUSINESS_LOCALE=en_US
# AMAZON_BUSINESS_SHIPPING_POSTAL_CODE=60601
# AMAZON_BUSINESS_TIMEOUT_MS=20000
#
# Required for purchase submission / approval execution:
# AMAZON_BUSINESS_SHIPPING_FULL_NAME=
# AMAZON_BUSINESS_SHIPPING_PHONE_NUMBER=
# AMAZON_BUSINESS_SHIPPING_COMPANY_NAME=
# AMAZON_BUSINESS_SHIPPING_ADDRESS_LINE1=
# AMAZON_BUSINESS_SHIPPING_ADDRESS_LINE2=
# AMAZON_BUSINESS_SHIPPING_CITY=
# AMAZON_BUSINESS_SHIPPING_STATE_OR_REGION=
# AMAZON_BUSINESS_SHIPPING_POSTAL_CODE=
# AMAZON_BUSINESS_SHIPPING_COUNTRY_CODE=US
#
# Safety mode:
# AMAZON_BUSINESS_ORDER_MODE=trial
# AMAZON_PURCHASE_APPROVAL_TTL_MINUTES=30

# 6) Alexa voice ingress (optional)
# This makes Alexa another way to talk to Andrea.
# Recommended first rollout:
# - keep request verification ON
# - keep the skill private / in developer mode
# - set ALEXA_ALLOWED_USER_IDS to your own Alexa user/person IDs
# - point ALEXA_TARGET_GROUP_FOLDER at main if you want shared context with Telegram
#
# Required:
# ALEXA_SKILL_ID=amzn1.ask.skill.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Optional defaults:
# ALEXA_HOST=127.0.0.1
# ALEXA_PORT=4300
# ALEXA_PATH=/alexa
# ALEXA_VERIFY_SIGNATURE=true
# ALEXA_REQUIRE_ACCOUNT_LINKING=false
# ALEXA_ALLOWED_USER_IDS=amzn1.ask.account...,amzn1.ask.person...
# ALEXA_TARGET_GROUP_FOLDER=main

# Optional OpenAI integrations (e.g., transcription skills)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional model override for Claude Agent SDK inside containers.
# Useful for OpenAI-compatible gateways that do not support the latest
# Claude default aliases yet.
# NANOCLAW_AGENT_MODEL=claude-3-5-sonnet-latest

# Channel credentials (enable one or more)
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=
# DISCORD_BOT_TOKEN=
