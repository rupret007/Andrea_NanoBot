{
  "name": "nanoclaw",
  "version": "1.2.41",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "check:node": "node scripts/check-node-version.js",
    "prebuild": "npm run check:node",
    "prestart": "npm run check:node",
    "predev": "npm run check:node",
    "pretypecheck": "npm run check:node",
    "presetup": "npm run check:node",
    "preauth": "npm run check:node",
    "prebuild:openclaw-market": "npm run check:node",
    "prelint": "npm run check:node",
    "pretest": "npm run check:node",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "build:openclaw-market": "tsx scripts/build-openclaw-market.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:major": "tsx scripts/test-major-iteration.ts",
    "test:major:ci": "tsx scripts/test-major-iteration.ts --skip-live-verify"
  },
  "dependencies": {
    "@onecli-sh/sdk": "^0.2.0",
    "ask-sdk-core": "^2.14.0",
    "ask-sdk-express-adapter": "^2.14.0",
    "ask-sdk-model": "^1.86.0",
    "better-sqlite3": "11.10.0",
    "cron-parser": "5.5.0",
    "grammy": "^1.39.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22 <23"
  }
}
